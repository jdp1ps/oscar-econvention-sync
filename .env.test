# Copy this file to .env and fill in the values
# Path where the "load" task will generate adapted JSON files
ECONVENTION_TO_OSCAR_OUTPUT_DIR=/home/user/airflow/data

OSCAR_CLI_WORKING_DIRECTORY=/var/www/oscar
REMOTE_OSCAR_OUTPUT_DIR=/home/user/Depot_distant
SSH_KEY_PATH=/home/user/.ssh/id_ed25519
SSH_USER=user
SSH_HOST=localhost


OSCAR_TO_ECONVENTION_OUTPUT_DIR=/home/user/depot
POSTGRES_CONN_ID=oscar_db
AIRFLOW_CONN_OSCAR_DB=postgresql://oscar:azerty@localhost:5432/oscar_dev

REDIS_CONN_ID=redis_cache
AIRFLOW_CONN_REDIS_CACHE=redis://:@localhost:6379/0

CONVENTION_TYPE_CSV_FILE=/home/user/oscar-econvention-sync/samples/TypeConventionSample.csv

CONVENTION_SOUS_TYPE_CSV_FILE=/home/user/oscar-econvention-sync/samples/SousTypeConventionSample.csv

TYPE_PARENT_COLUMN_NAME=TypeParent
TYPE_PARENT_VALUE=Recherche
VALUE_COLUMN_NAME=Title

BASCULE_ECONVENTION_ID=5

ACTIVITY_TYPE_CSV_FILE=/home/user/oscar-econvention-sync/samples/ActivityTypeSample.csv