# Copy this file to .env and fill in the values
# Path where the "load" task will generate adapted JSON files
ECONVENTION_TO_OSCAR_OUTPUT_DIR=/home/user/airflow/data

FALLBACK_OUTPUT_DIR=/home/user/airflow/emergency

OSCAR_HOME=/var/www/oscar

POSTGRES_CONN_ID=postgres_oscar

CONVENTION_TYPE_CSV_FILE=samples/TypeConventionSample.csv

CONVENTION_SOUS_TYPE_CSV_FILE=samples/SousTypeConventionSample.csv

TYPE_PARENT_COLUMN_NAME=TypeParent
TYPE_PARENT_VALUE=Pédagogie
VALUE_COLUMN_NAME=Title

BASCULE_ECONVENTION_ID=5